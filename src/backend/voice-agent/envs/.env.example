# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Provider selection — change these to switch without rewriting code ────────
STT_PROVIDER=openai          # openai | deepgram | google
STT_MODEL=whisper-1          # whisper-1 | nova-2 | nova-3 | telephony

LLM_PROVIDER=openai          # openai | anthropic | google
LLM_MODEL=gpt-4o-mini        # gpt-4o-mini | claude-3-5-haiku-20241022 | gemini-2.0-flash

TTS_PROVIDER=elevenlabs      # elevenlabs | google | openai | cartesia
TTS_VOICE=                   # leave empty to use provider default below

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Deepgram ──────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── Google Cloud STT + TTS ───────────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=./envs/credentials.json   # local dev
GOOGLE_CREDENTIALS_JSON=                           # AWS (paste full JSON string)
GOOGLE_STT_MODEL=telephony
GOOGLE_TTS_VOICE=vi-VN-Neural2-A

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Adam (multilingual)
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Cartesia ──────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# ── Downstream services ───────────────────────────────────────────────────────
CALL_LOGGER_URL=http://localhost:8001   # leave empty to skip saving call records locally
TRIP_SERVICE_URL=http://localhost:8002

# ── Silence tracker (local / iOS simulator has no real mic) ───────────────────
SILENCE_TRACKER_ENABLED=true
SILENCE_THRESHOLD_SECONDS=0          # 0 = driver 15s / customer 20s
SILENCE_MAX_CONSECUTIVE=3
SILENCE_END_SESSION=false            # set true in prod; false keeps simulator sessions alive

ENV=local
